class Solution {
public:
    vector<int> numberOfPairs(vector<int>& nums) {
        unordered_map<int,int>mp;
        int a=0,b=0;
        for(int x:nums){
            mp[x]++;
        }
        for (auto const& m : mp){
            a+=m.second/2;
            b+=m.second%2;
        } 
        vector<int>x={a,b};
        return x;
    }
};
