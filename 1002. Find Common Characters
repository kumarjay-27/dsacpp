class Solution {
public:
    vector<string> commonChars(vector<string>& words) {
         vector<int> freq(26, INT_MAX);

        for (string &word : words) {
            vector<int> cnt(26, 0);

            for (char c : word) {
                cnt[c - 'a']++;
            }

            for (int i = 0; i < 26; i++) {
                freq[i] = min(freq[i], cnt[i]);
            }
        }

        vector<string> ans;

        for (int i = 0; i < 26; i++) {
            while (freq[i]--) {
                ans.push_back(string(1, 'a' + i));
            }
        }

        return ans;
    }
};
