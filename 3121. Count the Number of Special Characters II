class Solution {
public:
    int numberOfSpecialChars(string word) {
       int n= word.length();
       int count=0;
       vector<int>lstsm(26,-1);
       vector<int>fstlar(26,-1); 
       for(int i=0;i<n;i++){
        char ch= word[i];
        if(islower(ch))
        {
            lstsm[ch-'a']=i;
        }
        else {
            if(fstlar[ch-'A']==-1){
                fstlar[ch-'A']=i;
            }
        }
       }
       for(int i=0;i<26;i++){
        if(lstsm[i]!=-1 && fstlar[i]!=-1&& lstsm[i]<fstlar[i]) count++;
       }
    return count;
    }
};
