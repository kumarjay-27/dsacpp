class Solution {
public:
    vector<int> leftRightDifference(vector<int>& nums) {
        int totalsum;
        for(int x:nums){
            totalsum+=x;
        }
        int left=0;
        int right;
        vector<int>res;
        for(int val:nums){
            right=totalsum-left-val;
            res.push_back(abs(right-left));
            left+=val;
        }
        return res;
    }
};
