class Solution {
public:
    vector<string> sortPeople(vector<string>& names, vector<int>& heights) {
      map<int,string,greater<int>>mpp ;//greater<int> for storing in descending order
      for(int i=0;i<names.size();i++){
        mpp[heights[i]]=names[i];
      }
      vector<string>res;
      for(auto &i:mpp){
        res.push_back(i.second);
      }
      return res;
    }
};
