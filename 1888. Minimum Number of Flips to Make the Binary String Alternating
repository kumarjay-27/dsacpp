class Solution {
public:
    int minFlips(string s) {
        int n = s.length();

        int res = INT_MAX;
        int flip1 = 0;
        int flip2 = 0;

        int i = 0;
        int j = 0;

        while (j < 2 * n) {

            char expS1 = (j % 2) ? '1' : '0';
            char expS2 = (j % 2) ? '0' : '1';

            if (s[j % n] != expS1) {
                flip1++;
            }
            if (s[j % n] != expS2) {
                flip2++;
            }

            if (j - i + 1 > n) { 
                expS1 = (i % 2) ? '1' : '0';
                expS2 = (i % 2) ? '0' : '1';

                if (s[i % n] != expS1) {
                    flip1--;
                }

                if (s[i % n] != expS2) {
                    flip2--;
                }

                i++;
            }

            if (j - i + 1 == n) {
                res = min({res, flip1, flip2});
            }

            j++;
        }
        return res;
    }
};
