class Solution {
public:
    int calPoints(vector<string>& operations) {
        vector<int>ans;
        for(auto ch:operations){
            if(ch=="+"){
                ans.push_back(ans[ans.size()-1]+ans[ans.size()-2]);
            }
            else if(ch=="D"){
                ans.push_back(ans.back()*2);
            }
            else if(ch=="C")
            {
                ans.pop_back();
            }
            else {
                ans.push_back(stoi(ch));
            }
        }
        int sum=0;
        for(int x:ans){
            sum+=x;
        }
        return sum;
    }
};
