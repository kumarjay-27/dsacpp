class Solution {
public:
    string processStr(string s) {
        string st="";
        for(char ch:s){
            if(isalnum(ch)){
                st+=tolower(ch);
            }
           else if(ch=='*'){
            if(!st.empty())
            st.pop_back();
           }
           else if(ch=='#') st=st+st;
           else reverse(st.begin(),st.end());
        }
        return st;
    }
};
