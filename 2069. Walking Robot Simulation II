class Robot {
public:
    int w, h;
    int x, y;
    int dir; 
    int cycle;

    vector<string> dname{"East","North","West","South"};
    vector<pair<int,int>> dirs{{1,0},{0,1},{-1,0},{0,-1}};

    Robot(int width, int height) {
        w = width;
        h = height;
        x = 0;
        y = 0;
        dir = 0; 

        cycle = 2 * (w + h - 2);
    }
    
    void step(int num) {
        num %= cycle;
        if(num == 0 && x == 0 && y == 0) {
            dir = 3; 
            return;
        }

        while(num--) {
            int nx = x + dirs[dir].first;
            int ny = y + dirs[dir].second;
            if(nx < 0 || nx >= w || ny < 0 || ny >= h) {
                dir = (dir + 1) % 4;
                nx = x + dirs[dir].first;
                ny = y + dirs[dir].second;
            }

            x = nx;
            y = ny;
        }
    }
    
    vector<int> getPos() {
        return {x, y};
    }
    
    string getDir() {
        return dname[dir];
    }
};
