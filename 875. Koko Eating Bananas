class Solution {
public:
    int minEatingSpeed(vector<int>& piles, int h) {
       int low=1;
       int high=*max_element(piles.begin(),piles.end()); // derefernce of the maximum element address
       while(low<high){
        int mid = low+(-low+high)/2;
        int k=0;
        for(auto &i:piles){
            k+=(int)ceil((double)i/mid);
        }
        if(k<=h){
            high =mid;
        } 
        else low= mid+1;
       }
       return low;
    }
};
