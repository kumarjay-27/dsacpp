class Solution {
public:
    int minOperations(string s) {
        int len = s.length();
        int st1=0;//010101
        int st2=0;//101010;
        for(int i=0;i<len;i++){
            if(i%2==0){
                if(s[i]=='0') st2++;
                else st1++;
            }
            else{
                if(s[i]=='0') st1++;
                else st2++;
            }
        }
        return min(st1,st2);
    }
};
