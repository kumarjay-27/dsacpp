class Solution {
public:
    int thirdMax(vector<int>& nums) {
        set<int>num;
        for(int i:nums){
            num.insert(i);
        }
        nums.assign(num.begin(), num.end());
        sort(nums.begin(),nums.end());
        if(nums.size()<3) return nums[nums.size()-1];
        return nums[nums.size()-3];
    }
};
