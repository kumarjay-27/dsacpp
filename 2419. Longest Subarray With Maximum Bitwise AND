class Solution {
public:
    int longestSubarray(vector<int>& nums) {
        int maxi = *max_element(nums.begin(),nums.end());
        int ans=0;
        int ct=0;
        for(int x:nums){
            if(x==maxi){
                ct++;
                ans=max(ans,ct);
            }
            else ct=0;
        }
        return ans;
    }
};
