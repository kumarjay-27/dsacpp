class Solution {
public:
bool isSafe(vector<vector<char>>&board,int row,int col,char ch){
    for(int i=0;i<9;i++){
        if(board[row][i]==ch  || board[i][col]==ch) return false;
    }
    int currRow=(row/3)*3;
    int currCol =(col/3)*3;
    for(int i=currRow;i<=currRow+2;i++){
        for(int j=currCol;j<=currCol+2;j++){
            if(board[i][j]==ch) return false;
        }
    }
    return true;
}
bool solve(vector<vector<char>>& board, int row,int col){
    if(row==9) return true;
    int nxtRow =row, nxtCol=col+1;
    if(nxtCol==9){
        nxtRow=row+1;
        nxtCol=0;
    }
    if(board[row][col]!='.') return solve(board,nxtRow,nxtCol);
    for(char i='1';i<='9';i++){
        if(isSafe(board,row,col,i)){
            board[row][col]=i;
            if(solve(board,nxtRow,nxtCol)) return true;
            board[row][col]='.';
        }
    }
    return false;
}
    void solveSudoku(vector<vector<char>>& board) {
        solve(board,0,0);
    }
};
