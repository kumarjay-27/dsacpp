class Solution {
public:
    int findPeakElement(vector<int>& arr) {
        int n= arr.size();
        int low=0;
        int high=n-1;
        int mid;
        while(low<=high){
            mid= low+(high-low)/2;
            if((mid==0||arr[mid]>arr[mid-1]) && (mid==n-1 || arr[mid]>arr[mid+1]))  return mid;
            else if(mid>0 && arr[mid-1]>arr[mid]) high = mid-1;
            else low = mid+1;
        }
        return low;
    }
};
