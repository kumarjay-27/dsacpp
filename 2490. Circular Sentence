class Solution {
public:
    bool isCircularSentence(string sentence) {
        int n= sentence.length();
        for(int i=0;i<n;i++){
            if(sentence.at(i)==' '){
                if(sentence.at(i-1)!=sentence.at(i+1)) return false;
        }

        }
        if(sentence.at(0)!=sentence.at(n-1)) return false;
        return true;
    }
};
