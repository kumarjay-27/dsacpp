class Solution {
public:
    void result(string curr, int n, vector<string>&sol){
        if(curr.length()==n){
            sol.push_back(curr);
            return;
        }
        for(char ch='a';ch<='c';ch++){
            if(!curr.empty() && curr.back()==ch) continue;
            curr.push_back(ch);
            result(curr,n,sol);
            curr.pop_back();
        }
    }
    string getHappyString(int n, int k) {
       vector<string>sol;
       string curr="";
       result(curr,n,sol);
       if(sol.size()<k) return "";
       return sol[k-1];
    }
};
