class Solution {
public:
    double findMaxAverage(vector<int>& arr, int k) {
        int r = 0, l = 0;
        double maxavg = INT_MIN, sum = 0;
        while (r < arr.size()) {
            sum += arr[r];
            if ((r - l + 1) == k) {
                double x = sum / k;
                maxavg = max(maxavg, x);
                sum -= arr[l];
                l++;
            }
            r++;
        }
        return maxavg;
    }
};
