class Solution {
public:
    int iswave(int num){
        string x= to_string(num);
        int t=0;
        for(int i=1;i<x.length()-1;i++){
            if(x[i]<x[i-1]&&x[i]<x[i+1]) t++;
            if(x[i]>x[i-1]&&x[i]>x[i+1]) t++;
        }
        return t;
    }
    int totalWaviness(int num1, int num2) {
        int count=0;
        for(int i=num1;i<=num2;i++){
            count=count+iswave(i);
        }
        return count;
    }
};
