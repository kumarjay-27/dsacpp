class Solution {
public:
bool isSpecial(int i,int j, vector<vector<int>>& mat){
    int n=mat[0].size();
    int m= mat.size();
    for(int col=0;col<n;col++){
        if(col!=j && mat[i][col]==1) return false;
    }
    for(int row=0;row<m;row++){
        if(row!=i && mat[row][j]==1) return false;
    }
    return true;
}
    int numSpecial(vector<vector<int>>& mat) {
        int n= mat[0].size();
        int m= mat.size();
        int count=0;
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(mat[i][j]==1){
                    if(isSpecial(i,j,mat)) count++;
                }
            }
        }
            return count;
    }
};
